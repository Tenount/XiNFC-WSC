Checks: >
  bugprone-*,
  clang-analyzer-*,
  cert-*,
  readability-*,
  misc-*,
  -cert-err33-c,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-size,
  -misc-include-cleaner,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling

# OpenWrt fortifies memcpy/snprintf via SDK fortify-headers (invisible to
# clang-tidy on Alpine). See docs/linter-suppressions.md for details.
#
# OpenWrt follows Linux kernel coding style: lower_case (snake_case) for
# functions, structs, and variables; UPPER_CASE for macros and constants.
CheckOptions:
  readability-identifier-naming.FunctionCase: lower_case
  readability-identifier-naming.StructCase: lower_case
  readability-identifier-naming.VariableCase: lower_case
  readability-identifier-naming.GlobalConstantCase: UPPER_CASE
