root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{c,h}]
indent_style = space
indent_size = 4

[[shell]]
indent_style = space
indent_size = 4
switch_case_indent = true

[Makefile]
indent_style = tab
